{
  "redirects": [
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "the-ai-agent-index.vercel.app"
        }
      ],
      "destination": "https://theaiagentindex.com/$1",
      "permanent": true
    }
  ],
  "crons": [
    {
      "path": "/api/cron/github-stars",
      "schedule": "0 6 * * 1"
    }
  ]
}